// Autoflow — Prisma Schema
// Multi-schema: master_data, transactions, warehouse, reports

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["master_data", "transactions", "warehouse", "reports"]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  CASHIER
  STORE
  SUPERVISOR
  MANAGER
  CFO
  ADMIN

  @@schema("master_data")
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  roles        Role[]   @default([])
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]

  @@map("users")
  @@schema("master_data")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  token     String    @unique
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt], name: "idx_refresh_token_user_active")
  @@map("refresh_tokens")
  @@schema("master_data")
}

// ─── Reports Schema ──────────────────────────────────────────────────────────

model AlertLog {
  id           String   @id @default(uuid()) @db.Uuid
  alertCode    String   @map("alert_code")
  alertMessage String   @map("alert_message")
  txType       String   @map("tx_type")
  txData       Json     @map("tx_data")
  itemId       String?  @map("item_id")
  warehouseId  String?  @map("warehouse_id")
  period       String?
  userId       String   @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([alertCode, createdAt], name: "idx_alert_log_code_created")
  @@index([userId], name: "idx_alert_log_user")
  @@index([txType], name: "idx_alert_log_tx_type")
  @@index([createdAt], name: "idx_alert_log_created")
  @@map("alert_log")
  @@schema("reports")
}
